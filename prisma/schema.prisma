generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // Profile
  height        Float?
  weight        Float?
  age           Int?
  gender        String?
  goalType      String?
  dailyCalories Int?

  // Progression
  xp            Int    @default(0)
  level         Int    @default(1)
  rank          String @default("E")

  // Stats
  streakDays     Int     @default(0)
  lastStreakDate String?  // YYYY-MM-DD of last day all quests were completed
  lastActiveAt   DateTime?

  accounts        Account[]
  sessions        Session[]
  questLogs       QuestLog[]
  dailyQuests     DailyQuest[]
  shadows         UserShadow[]
  weapons         UserWeapon[]
  skills          UserSkill[]
  guildMembership GuildMember?
  sentDuels       Duel[]       @relation("DuelChallenger")
  receivedDuels   Duel[]       @relation("DuelChallenged")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Quest {
  id          String @id @default(cuid())
  title       String
  description String
  type        String
  category    String
  xpReward    Int
  difficulty  String

  questLogs QuestLog[]
}

model QuestLog {
  id          String   @id @default(cuid())
  userId      String
  questId     String
  completedAt DateTime @default(now())
  xpEarned    Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id])
}

model DailyQuest {
  id          String    @id @default(cuid())
  userId      String
  date        String    // YYYY-MM-DD
  category    String    // calories | water | workout | sleep | tasks
  title       String
  description String
  target      Float
  current     Float     @default(0)
  unit        String
  xpReward    Int
  difficulty  String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, category])
}

model Shadow {
  id          String @id @default(cuid())
  name        String
  type        String
  description String
  unlockReq   String
  rarity      String
  imageUrl    String?

  userShadows UserShadow[]
}

model UserShadow {
  id         String   @id @default(cuid())
  userId     String
  shadowId   String
  unlockedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shadow Shadow @relation(fields: [shadowId], references: [id])

  @@unique([userId, shadowId])
}

model Weapon {
  id           String @id @default(cuid())
  name         String
  description  String
  rankRequired String
  imageUrl     String?

  userWeapons UserWeapon[]
}

model UserWeapon {
  id         String   @id @default(cuid())
  userId     String
  weaponId   String
  unlockedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  weapon Weapon @relation(fields: [weaponId], references: [id])

  @@unique([userId, weaponId])
}

model Skill {
  id          String @id @default(cuid())
  name        String
  description String
  unlockReq   String

  userSkills UserSkill[]
}

model UserSkill {
  id         String   @id @default(cuid())
  userId     String
  skillId    String
  unlockedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model Guild {
  id         String   @id @default(cuid())
  name       String   @unique
  inviteCode String   @unique @default(cuid())
  leaderId   String
  guildXP    Int      @default(0)
  guildLevel Int      @default(1)

  members    GuildMember[]
  raidBosses RaidBoss[]
  activities GuildActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuildMember {
  id        String   @id @default(cuid())
  guildId   String
  userId    String   @unique
  role      String   @default("member")
  weeklyXP  Int      @default(0)
  weekStart String   @default("")
  joinedAt  DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model RaidBoss {
  id        String @id @default(cuid())
  guildId   String
  bossKey   String
  name      String
  maxHP     Int
  currentHP Int
  weekStart String
  weekEnd   String
  defeated  Boolean @default(false)
  xpReward  Int

  damageLog RaidDamageLog[]
  guild     Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, weekStart])
  @@index([guildId])
}

model RaidDamageLog {
  id         String @id @default(cuid())
  raidBossId String
  userId     String
  damage     Int
  date       String

  raidBoss RaidBoss @relation(fields: [raidBossId], references: [id], onDelete: Cascade)

  @@unique([raidBossId, userId, date])
  @@index([raidBossId])
}

model Duel {
  id           String  @id @default(cuid())
  challengerId String
  challengedId String
  xpWager      Int     @default(50)
  startDate    String
  endDate      String
  status       String  @default("pending")
  winnerId     String?

  challenger User @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged User @relation("DuelChallenged", fields: [challengedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([challengerId])
  @@index([challengedId])
  @@index([status])
}

model GuildActivity {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  type      String
  detail    String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
}
